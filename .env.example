# NorthClaw Environment Configuration
# Copy this file to .env and fill in the values.

# --- Authentication (required — pick one) ---
ANTHROPIC_API_KEY=
# CLAUDE_CODE_OAUTH_TOKEN=

# --- Compliance ---
NORTHCLAW_SENDER_NAME=
NORTHCLAW_MAILING_ADDRESS=
NORTHCLAW_CONTACT_URL=
NORTHCLAW_UNSUBSCRIBE_URL=
NORTHCLAW_CONSENT_MODE=log-only  # log-only | strict

# --- Performance Profile ---
NORTHCLAW_PROFILE=conservative  # conservative | standard | performance

# --- Inference Provider ---
NORTHCLAW_INFERENCE_PROVIDER=anthropic  # anthropic | vertex | telus (future)

# --- Vertex AI (when CLAUDE_CODE_USE_VERTEX=1) ---
# Note: Claude is not yet available in northamerica-northeast1 (Montreal).
# us-east5 (Columbus, Ohio) is the closest regional endpoint.
# Data at rest stays in Canada; inference routes to nearest US region.
# See docs/VERTEX-AI.md for full sovereignty roadmap.
CLAUDE_CODE_USE_VERTEX=
CLOUD_ML_REGION=us-east5  # us-east5 is closest to Canada. See docs/VERTEX-AI.md

# --- Channel Credentials ---
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
